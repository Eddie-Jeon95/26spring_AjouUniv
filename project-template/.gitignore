# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.env
*.egg-info/
dist/
build/

# 데이터 (raw/processed - 용량 큰 파일은 git에 올리지 않음)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# 모델 가중치 (용량 이슈 - HF Hub 사용 권장)
*.pt
*.pth
*.pkl
*.joblib
*.h5
*.ckpt
/models/

# 실험 실행 산출물
experiments/runs/*
!experiments/runs/.gitkeep

# 운영 로그 (개인정보 및 용량 이슈)
logs/*
!logs/.gitkeep

# Streamlit secrets
.streamlit/secrets.toml

# Claude Code local permissions
.claude/settings.local.json

# 환경 변수
.env
.env.local
.env.*.local

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Docker
*.env.docker
